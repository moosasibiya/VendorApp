{
  "name": "vendorapp",
  "private": true,
  "packageManager": "pnpm@9.0.0",
  "engines": {
    "node": ">=18"
  },
  "scripts": {
    "docker:up": "docker compose up -d --wait",
    "docker:down": "docker compose down",
    "dev:local": "pnpm run docker:up && pnpm dev",
    "dev": "pnpm --filter @vendorapp/shared build && turbo dev",
    "db:migrate": "pnpm --filter @vendorapp/api run db:migrate",
    "migrate:deploy": "pnpm --filter @vendorapp/api run migrate:deploy",
    "migrate:status": "pnpm --filter @vendorapp/api run migrate:status",
    "db:seed": "pnpm --filter @vendorapp/api run db:seed:core",
    "db:reset": "pnpm --filter @vendorapp/api run db:reset",
    "build": "turbo build",
    "lint": "turbo lint",
    "test": "pnpm run docker:up && pnpm run db:migrate && pnpm --filter @vendorapp/api run test -- --runInBand && pnpm --filter @vendorapp/api run test:e2e -- --runInBand",
    "typecheck": "turbo typecheck",
    "smoke:prelaunch": "node scripts/smoke-prelaunch.mjs",
    "format": "prettier --write ."
  },
  "devDependencies": {
    "turbo": "^2.0.0",
    "prettier": "^3.3.3",
    "next": "16.2.4"
  }
}
