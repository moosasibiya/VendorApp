# Docker Compose local services
POSTGRES_DB=vendorapp
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_PORT=5432
REDIS_PORT=6379

# Local Prisma connection strings.
# Production DATABASE_URL/DIRECT_URL must be configured in the production environment, not copied from this file.
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vendorapp?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/vendorapp?schema=public

# Local app origins
WEB_ORIGIN=http://localhost:3000
NEXT_PUBLIC_WEB_URL=http://localhost:3000
NEXT_PUBLIC_API_BASE_URL=http://localhost:4000/api

# Email provider (optional locally; required for production email delivery)
RESEND_API_KEY=
EMAIL_FROM="Vendr Studios <noreply@vendr.studio>"
