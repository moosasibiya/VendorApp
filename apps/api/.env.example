# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vendorapp?schema=public
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/vendorapp?schema=public

# Auth/session secrets
# Production: use unique 32+ character random values, rotate before launch.
SESSION_SECRET=replace-with-32-plus-character-random-secret
JWT_SECRET=replace-with-32-plus-character-random-secret
# Reserved for a future refresh-token flow. Current pre-launch auth does not read this value.
JWT_REFRESH_SECRET=replace-with-32-plus-character-random-secret
JWT_EXPIRES_IN=7d

# CSRF
# Current CSRF protection uses a double-submit cookie/header token.
CSRF_COOKIE_NAME=vendrman_csrf

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
GOOGLE_OAUTH_STATE_SECRET=
GOOGLE_OAUTH_STATE_TTL_SECONDS=600
GOOGLE_OAUTH_PROMPT=select_account
GOOGLE_OAUTH_ACCESS_TYPE=online

# App URLs
# WEB_ORIGIN may be comma-separated for preview/staging origins.
WEB_ORIGIN=http://localhost:3000
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000

# Password reset
AUTH_EXPOSE_RESET_TOKEN=false
RESET_TOKEN_PEPPER=replace-with-32-plus-character-random-secret
REQUIRE_EMAIL_VERIFICATION=true
BACKUP_CODE_PEPPER=replace-with-32-plus-character-random-secret
AUTH_PASSWORD_RESET_EXPIRES_MINUTES=60
AUTH_MFA_ISSUER=Vendr Studios

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM="Vendr Studios <noreply@yourdomain.com>"

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
RATE_LIMIT_KEY_PREFIX=vendorapp

# File storage (Cloudflare R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=vendorapp-media
R2_PUBLIC_URL=

# Cookie and proxy settings
AUTH_COOKIE_NAME=vendrman_auth
AUTH_COOKIE_SAME_SITE=lax
# Production over HTTPS: true
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=
TRUST_PROXY=false

# Auth hardening
AUTH_MAX_FAILED_LOGIN_ATTEMPTS=10
AUTH_LOCKOUT_MINUTES=15
AUTH_MAX_LOGIN_ATTEMPTS_PER_WINDOW=5
AUTH_LOGIN_ATTEMPT_WINDOW_SECONDS=60

# Environment
NODE_ENV=development
