# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/vendorapp
DIRECT_URL=postgresql://postgres:postgres@localhost:5432/vendorapp

# Session
SESSION_SECRET=change-me-in-production

# CSRF
CSRF_SECRET=change-me-in-production
CSRF_COOKIE_NAME=vendrman_csrf

# JWT / auth token compatibility
JWT_SECRET=change-me-in-production
JWT_EXPIRES_IN=7d

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:4000/api/auth/google/callback
GOOGLE_OAUTH_STATE_SECRET=
GOOGLE_OAUTH_STATE_TTL_SECONDS=600
GOOGLE_OAUTH_PROMPT=select_account
GOOGLE_OAUTH_ACCESS_TYPE=online

# App URLs
WEB_ORIGIN=http://localhost:3000
API_PORT=4000

# Password reset
AUTH_EXPOSE_RESET_TOKEN=false
RESET_TOKEN_PEPPER=change-me-in-production
REQUIRE_EMAIL_VERIFICATION=true
BACKUP_CODE_PEPPER=change-me-in-production
AUTH_PASSWORD_RESET_EXPIRES_MINUTES=60
AUTH_MFA_ISSUER=VendorApp

# Email (Resend)
RESEND_API_KEY=
EMAIL_FROM=noreply@yourdomain.com

# Upstash Redis (rate limiting)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
REQUIRE_DISTRIBUTED_RATE_LIMIT=false
RATE_LIMIT_KEY_PREFIX=vendorapp

# File storage (Cloudflare R2)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=vendorapp-media
R2_PUBLIC_URL=

# Payments (Payfast)
PAYFAST_MERCHANT_ID=
PAYFAST_MERCHANT_KEY=
PAYFAST_PASSPHRASE=
PAYFAST_SANDBOX=true
PAYFAST_NOTIFY_URL=
API_PUBLIC_URL=http://localhost:4000
PLATFORM_FEE_PERCENT=10

# Cookie and proxy settings
AUTH_COOKIE_NAME=vendrman_auth
AUTH_COOKIE_SAME_SITE=lax
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_DOMAIN=
TRUST_PROXY=false

# Auth hardening
AUTH_MAX_FAILED_LOGIN_ATTEMPTS=10
AUTH_LOCKOUT_MINUTES=15
AUTH_MAX_LOGIN_ATTEMPTS_PER_WINDOW=5
AUTH_LOGIN_ATTEMPT_WINDOW_SECONDS=60

# Environment
NODE_ENV=development
