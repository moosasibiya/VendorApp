generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

enum AccountType {
  CREATIVE
  CLIENT
  AGENCY
}

enum UserRole {
  CLIENT
  ARTIST
  AGENCY
  ADMIN
  SUB_ADMIN
}

enum BookingStatus {
  PENDING                  @map("Pending")
  CONFIRMED                @map("Confirmed")
  BOOKED
  AWAITING_START_CODE
  IN_PROGRESS              @map("InProgress")
  AWAITING_CLIENT_APPROVAL
  COMPLETED                @map("Completed")
  DISPUTED                 @map("Disputed")
  PAYOUT_PENDING
  PAYOUT_RELEASED
  CANCELLED                @map("Cancelled")
}

enum PaymentStatus {
  UNPAID
  PAID
  REFUNDED
  FAILED
}

enum PaymentProvider {
  PAYFAST
}

enum MessageType {
  TEXT
  IMAGE
  FILE
  SYSTEM
}

enum NotificationType {
  BOOKING_REQUEST
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  MESSAGE_RECEIVED
  PAYMENT_RECEIVED
  PAYMENT_FAILED
  REVIEW_RECEIVED
  SUPPORT_THREAD_CREATED
  SUPPORT_THREAD_UPDATED
  ARTIST_APPLICATION_UPDATED
  PAYOUT_STATUS_UPDATED
}

enum ArtistApplicationStatus {
  SUBMITTED
  PRELAUNCH_POOL
  WAITLISTED
  UNDER_REVIEW
  APPROVED
  REJECTED
  LIVE
}

enum OnboardingFeeModel {
  UPFRONT
  FIRST_BOOKING_DEDUCTION
}

enum ConversationKind {
  DIRECT
  BOOKING
  SUPPORT
}

enum SupportCategory {
  BOOKING_HELP
  PAYMENT_ISSUE
  PROFILE_ISSUE
  DISPUTE_HELP
  REFUND_HELP
  OTHER
}

enum SupportThreadStatus {
  OPEN
  AWAITING_USER
  ESCALATED
  RESOLVED
}

enum BookingVerificationStatus {
  NOT_REQUIRED
  PENDING
  VERIFIED
  FAILED
  MANUAL_OVERRIDE
}

enum PayoutStatus {
  NOT_READY
  PENDING
  ON_HOLD
  RELEASED
  MANUAL_REVIEW
}

model User {
  id                  String               @id @db.VarChar(64)
  fullName            String
  name                String
  username            String               @db.VarChar(30)
  usernameNormalized  String               @unique @db.VarChar(30)
  email               String               @unique
  emailNormalized     String               @unique
  googleId            String?              @unique @db.VarChar(191)
  role                UserRole             @default(CLIENT)
  accountType         AccountType
  avatarUrl           String?
  location            String?
  clientEventTypes    String[]             @default([])
  clientBudgetMin     Decimal?             @db.Decimal(10, 2)
  clientBudgetMax     Decimal?             @db.Decimal(10, 2)
  notificationPreferences Json?
  onboardingCompletedAt DateTime?
  isEmailVerified     Boolean              @default(false)
  isActive            Boolean              @default(true)
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
  passwordSalt        String
  passwordHash        String
  passwordResetHash   String?
  passwordResetExpiry DateTime?
  mfaEnabled          Boolean              @default(false)
  mfaSecret           String?
  mfaTempSecret       String?
  mfaBackupCodeHashes Json?
  failedLoginAttempts Int                  @default(0)
  lockoutUntil        DateTime?
  tokenVersion        Int                  @default(0)
  auditEvents         AuthAuditEvent[]
  artistProfile       Artist?              @relation("ArtistUserProfile")
  ownedAgency         Agency?              @relation("AgencyOwner")
  clientBookings      Booking[]            @relation("ClientBookings")
  reviews             Review[]             @relation("ReviewerReviews")
  sentMessages        Message[]            @relation("SenderMessages")
  notifications       Notification[]
  passwordResetTokens PasswordResetToken[]
  mediaUploads        MediaUpload[]
  bookingStatusEvents BookingStatusHistory[] @relation("BookingStatusHistoryActor")
  reviewedArtistApplications Artist[]        @relation("ArtistApplicationReviewedBy")
  approvedArtists            Artist[]        @relation("ArtistApprovedBy")
  liveEnabledArtists         Artist[]        @relation("ArtistLiveEnabledBy")
  supportAssignedConversations Conversation[] @relation("SupportConversationAssignee")
  updatedSystemSettings      SystemSetting[] @relation("SystemSettingUpdatedBy")
  bookingAuditEvents         BookingAuditEvent[] @relation("BookingAuditActor")

  @@index([emailNormalized])
  @@index([usernameNormalized])
  @@index([role])
  @@map("users")
}

model Artist {
  id                  String    @id @default(cuid()) @db.VarChar(64)
  userId              String?   @unique @db.VarChar(64)
  slug                String    @unique @db.VarChar(100)
  displayName         String
  name                String
  bio                 String    @default("")
  categoryId          String?   @db.VarChar(64)
  role                String
  location            String
  hourlyRate          Decimal   @default(0) @db.Decimal(10, 2)
  isAvailable         Boolean   @default(true)
  portfolioImages     String[]  @default([])
  portfolioLinks      String[]  @default([])
  tags                String[]  @default([])
  services            String[]  @default([])
  specialties         String[]  @default([])
  pricingSummary      String?
  availabilitySummary String?
  averageRating       Float     @default(0)
  totalReviews        Int       @default(0)
  profileViews        Int       @default(0)
  rating              String    @default("0.0") @db.VarChar(8)
  isVerified          Boolean   @default(false)
  onboardingCompleted Boolean   @default(false)
  applicationStatus   ArtistApplicationStatus @default(SUBMITTED)
  applicationSequence Int?      @unique
  applicationSubmittedAt DateTime?
  applicationReviewedAt DateTime?
  applicationReviewedByUserId String? @db.VarChar(64)
  applicationReviewNotes String?
  approvedAt          DateTime?
  approvedByUserId    String?   @db.VarChar(64)
  isLive              Boolean   @default(false)
  wentLiveAt          DateTime?
  liveEnabledByUserId String?   @db.VarChar(64)
  onboardingFeeModel  OnboardingFeeModel @default(FIRST_BOOKING_DEDUCTION)
  firstBookingOnboardingDeductionApplied Boolean @default(false)
  firstBookingOnboardingDeductionAt DateTime?
  normalCommissionRate Decimal  @default(15) @db.Decimal(5, 2)
  temporaryFirstBookingCommissionRate Decimal @default(25) @db.Decimal(5, 2)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  user                User?     @relation("ArtistUserProfile", fields: [userId], references: [id], onDelete: SetNull)
  category            Category? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  applicationReviewedBy User?   @relation("ArtistApplicationReviewedBy", fields: [applicationReviewedByUserId], references: [id], onDelete: SetNull)
  approvedBy          User?     @relation("ArtistApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  liveEnabledBy       User?     @relation("ArtistLiveEnabledBy", fields: [liveEnabledByUserId], references: [id], onDelete: SetNull)
  bookings            Booking[] @relation("ArtistBookings")
  reviews             Review[]  @relation("ArtistReviews")
  tierSnapshot        ArtistTierSnapshot?

  @@index([categoryId])
  @@index([isAvailable])
  @@index([applicationStatus])
  @@index([isLive])
  @@index([applicationSubmittedAt])
  @@map("artists")
}

model Agency {
  id          String    @id @default(cuid()) @db.VarChar(64)
  ownerId     String    @unique @db.VarChar(64)
  name        String
  slug        String    @unique
  description String
  logoUrl     String?
  website     String?
  contactName String?
  contactEmail String?
  isVerified  Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  owner       User      @relation("AgencyOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  bookings    Booking[]

  @@map("agencies")
}

model Category {
  id        String   @id @default(cuid()) @db.VarChar(64)
  name      String   @unique
  slug      String   @unique
  iconUrl   String?
  createdAt DateTime @default(now())
  artists   Artist[]

  @@map("categories")
}

model Booking {
  id                    String         @id @db.VarChar(64)
  clientId              String         @db.VarChar(64)
  artistId              String         @db.VarChar(64)
  agencyId              String?        @db.VarChar(64)
  title                 String
  description           String         @default("")
  eventDate             DateTime       @default(now())
  eventEndDate          DateTime?
  location              String
  status                BookingStatus  @default(PENDING)
  totalAmount           Decimal        @default(0) @db.Decimal(10, 2)
  platformFee           Decimal        @default(0) @db.Decimal(10, 2)
  artistPayout          Decimal        @default(0) @db.Decimal(10, 2)
  paymentProvider       PaymentProvider?
  paymentStatus         PaymentStatus  @default(UNPAID)
  stripePaymentIntentId String?
  paymentReference      String?        @unique
  paymentGatewayReference String?
  paymentInitiatedAt    DateTime?
  paymentPaidAt         DateTime?
  paymentFailedAt       DateTime?
  notes                 String?
  cancelledAt           DateTime?
  cancelReason          String?
  artistName            String
  artistInitials        String         @db.VarChar(3)
  date                  String
  amount                String
  applications          Int            @default(0)
  createdAt             DateTime       @default(now())
  updatedAt             DateTime       @updatedAt
  client                User           @relation("ClientBookings", fields: [clientId], references: [id], onDelete: Restrict)
  artist                Artist         @relation("ArtistBookings", fields: [artistId], references: [id], onDelete: Restrict)
  agency                Agency?        @relation(fields: [agencyId], references: [id], onDelete: SetNull)
  review                Review?
  conversations         Conversation[]
  statusHistory         BookingStatusHistory[]
  verificationCodeCiphertext String?
  verificationCodeSentAt DateTime?
  verificationCodeExpiresAt DateTime?
  verificationStatus   BookingVerificationStatus @default(NOT_REQUIRED)
  verificationAttempts Int @default(0)
  verificationEnteredAt DateTime?
  verificationEnteredByUserId String? @db.VarChar(64)
  verificationOverrideByUserId String? @db.VarChar(64)
  verificationOverrideReason String?
  jobStartedAt         DateTime?
  jobCompletedAt       DateTime?
  clientApprovedAt     DateTime?
  disputeOpenedAt      DateTime?
  disputeWindowEndsAt  DateTime?
  disputeWindowDays    Int @default(3)
  payoutStatus         PayoutStatus @default(NOT_READY)
  payoutPendingAt      DateTime?
  estimatedPayoutReleaseAt DateTime?
  payoutReleasedAt     DateTime?
  payoutHoldReason     String?
  payoutDelayDaysSnapshot Int @default(0)
  payoutOverrideByUserId String? @db.VarChar(64)
  payoutOverrideReason String?
  normalCommissionRate Decimal @default(15) @db.Decimal(5, 2)
  appliedCommissionRate Decimal @default(15) @db.Decimal(5, 2)
  onboardingExtraCutAmount Decimal @default(0) @db.Decimal(10, 2)
  auditEvents          BookingAuditEvent[]

  @@index([clientId])
  @@index([artistId])
  @@index([status])
  @@index([paymentStatus])
  @@index([paymentProvider])
  @@index([eventDate])
  @@index([agencyId])
  @@index([createdAt])
  @@index([verificationStatus])
  @@index([payoutStatus])
  @@index([disputeWindowEndsAt])
  @@index([estimatedPayoutReleaseAt])
  @@map("bookings")
}

model Review {
  id         String   @id @default(cuid()) @db.VarChar(64)
  bookingId  String   @unique @db.VarChar(64)
  reviewerId String   @db.VarChar(64)
  artistId   String   @db.VarChar(64)
  rating     Int
  comment    String
  isPublic   Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  booking    Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  reviewer   User     @relation("ReviewerReviews", fields: [reviewerId], references: [id], onDelete: Restrict)
  artist     Artist   @relation("ArtistReviews", fields: [artistId], references: [id], onDelete: Cascade)

  @@index([artistId])
  @@index([reviewerId])
  @@map("reviews")
}

model BookingStatusHistory {
  id         String        @id @default(cuid()) @db.VarChar(64)
  bookingId  String        @db.VarChar(64)
  fromStatus BookingStatus?
  toStatus   BookingStatus
  action     String        @db.VarChar(32)
  reason     String?
  actorUserId String?      @db.VarChar(64)
  actorName  String?
  actorRole  UserRole?
  createdAt  DateTime      @default(now())
  booking    Booking       @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  actor      User?         @relation("BookingStatusHistoryActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([actorUserId])
  @@index([createdAt])
  @@map("booking_status_history")
}

model Conversation {
  id            String    @id @default(cuid()) @db.VarChar(64)
  bookingId     String?   @db.VarChar(64)
  participantIds String[] @default([])
  kind          ConversationKind @default(DIRECT)
  subject       String?
  supportCategory SupportCategory?
  supportStatus SupportThreadStatus?
  supportTicketNumber String? @unique
  assignedAdminUserId String? @db.VarChar(64)
  resolvedAt    DateTime?
  lastMessageAt DateTime  @default(now())
  createdAt     DateTime  @default(now())
  booking       Booking?  @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  assignedAdmin User?     @relation("SupportConversationAssignee", fields: [assignedAdminUserId], references: [id], onDelete: SetNull)
  messages      Message[]

  @@index([bookingId])
  @@index([kind])
  @@index([supportStatus])
  @@index([supportCategory])
  @@index([assignedAdminUserId])
  @@index([lastMessageAt])
  @@map("conversations")
}

model Message {
  id             String       @id @default(cuid()) @db.VarChar(64)
  conversationId String       @db.VarChar(64)
  senderId       String       @db.VarChar(64)
  type           MessageType  @default(TEXT)
  content        String
  fileUrl        String?
  isRead         Boolean      @default(false)
  createdAt      DateTime     @default(now())
  conversation   Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender         User         @relation("SenderMessages", fields: [senderId], references: [id], onDelete: Restrict)

  @@index([conversationId])
  @@index([senderId])
  @@index([isRead])
  @@map("messages")
}

model Notification {
  id        String           @id @default(cuid()) @db.VarChar(64)
  userId    String           @db.VarChar(64)
  type      NotificationType
  title     String
  body      String
  isRead    Boolean          @default(false)
  metadata  Json?
  createdAt DateTime         @default(now())
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([isRead])
  @@map("notifications")
}

model PasswordResetToken {
  id        String   @id @default(cuid()) @db.VarChar(64)
  userId    String   @db.VarChar(64)
  tokenHash String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("password_reset_tokens")
}

model MediaUpload {
  id         String   @id @default(cuid()) @db.VarChar(64)
  uploaderId String   @db.VarChar(64)
  url        String
  key        String   @unique
  mimeType   String
  sizeBytes  Int
  isPublic   Boolean  @default(true)
  createdAt  DateTime @default(now())
  uploader   User     @relation(fields: [uploaderId], references: [id], onDelete: Cascade)

  @@index([uploaderId])
  @@map("media_uploads")
}

model AuthAuditEvent {
  id              String   @id @db.VarChar(64)
  userId          String?  @db.VarChar(64)
  emailNormalized String?
  eventType       String   @db.VarChar(64)
  success         Boolean
  ipAddress       String?  @db.VarChar(64)
  requestId       String?  @db.VarChar(128)
  metadata        Json?
  createdAt       DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([eventType])
  @@index([createdAt])
  @@map("auth_audit_events")
}

model SequenceCounter {
  key       String   @id @db.VarChar(64)
  value     Int      @default(0)
  updatedAt DateTime @updatedAt

  @@map("sequence_counters")
}

model SystemSetting {
  key             String   @id @db.VarChar(120)
  value           Json
  description     String?
  updatedAt       DateTime @updatedAt
  updatedByUserId String?  @db.VarChar(64)
  updatedBy       User?    @relation("SystemSettingUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([updatedAt])
  @@map("system_settings")
}

model BookingAuditEvent {
  id          String   @id @default(cuid()) @db.VarChar(64)
  bookingId   String   @db.VarChar(64)
  actorUserId String?  @db.VarChar(64)
  eventType   String   @db.VarChar(64)
  message     String?
  metadata    Json?
  createdAt   DateTime @default(now())
  booking     Booking  @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  actor       User?    @relation("BookingAuditActor", fields: [actorUserId], references: [id], onDelete: SetNull)

  @@index([bookingId])
  @@index([actorUserId])
  @@index([eventType])
  @@index([createdAt])
  @@map("booking_audit_events")
}

model ArtistTierDefinition {
  id          String   @id @default(cuid()) @db.VarChar(64)
  key         String   @unique @db.VarChar(64)
  name        String
  description String?
  sortOrder   Int
  isActive    Boolean  @default(true)
  thresholds  Json?
  benefits    Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  currentSnapshots  ArtistTierSnapshot[] @relation("ArtistTierSnapshotCurrent")
  evaluatedSnapshots ArtistTierSnapshot[] @relation("ArtistTierSnapshotEvaluated")
  manualSnapshots   ArtistTierSnapshot[] @relation("ArtistTierSnapshotManual")

  @@index([sortOrder])
  @@index([isActive])
  @@map("artist_tier_definitions")
}

model ArtistTierSnapshot {
  id                       String   @id @default(cuid()) @db.VarChar(64)
  artistId                 String   @unique @db.VarChar(64)
  currentTierId            String?  @db.VarChar(64)
  evaluatedTierId          String?  @db.VarChar(64)
  manualTierId             String?  @db.VarChar(64)
  manualOverrideReason     String?
  completedPlatformBookings Int     @default(0)
  verifiedPlatformBookings Int      @default(0)
  platformRevenue          Decimal  @default(0) @db.Decimal(12, 2)
  averageRating            Float    @default(0)
  cancellationCount        Int      @default(0)
  reliabilityScore         Float    @default(100)
  responseTimeMinutes      Int?
  disputeCount             Int      @default(0)
  disputeRate              Float    @default(0)
  profileCompleteness      Int      @default(0)
  repeatBookings           Int      @default(0)
  evaluationDetails        Json?
  lastEvaluatedAt          DateTime?
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  artist                   Artist   @relation(fields: [artistId], references: [id], onDelete: Cascade)
  currentTier              ArtistTierDefinition? @relation("ArtistTierSnapshotCurrent", fields: [currentTierId], references: [id], onDelete: SetNull)
  evaluatedTier            ArtistTierDefinition? @relation("ArtistTierSnapshotEvaluated", fields: [evaluatedTierId], references: [id], onDelete: SetNull)
  manualTier               ArtistTierDefinition? @relation("ArtistTierSnapshotManual", fields: [manualTierId], references: [id], onDelete: SetNull)

  @@index([currentTierId])
  @@index([evaluatedTierId])
  @@index([manualTierId])
  @@index([lastEvaluatedAt])
  @@map("artist_tier_snapshots")
}
